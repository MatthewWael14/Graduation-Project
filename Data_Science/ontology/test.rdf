    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#Assembly_Line_01 -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Assembly_Line_01">
        <rdf:type rdf:resource="http://example.org/ontology#Event"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionProcess"/>
        <rdf:type rdf:resource="http://example.org/ontology#RiskEvent"/>
        <ontology:hasCriticalityLevel>High</ontology:hasCriticalityLevel>
        <ontology:hasDowntimeDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</ontology:hasDowntimeDuration>
        <ontology:hasRiskStatus>Confirmed</ontology:hasRiskStatus>
        <ontology:isCriticalPath rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ontology:isCriticalPath>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Critical_Component -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Critical_Component">
        <rdf:type rdf:resource="http://example.org/ontology#RawMaterial"/>
        <ontology:affectsProcess rdf:resource="http://example.org/ontology#Main_Assembly_Line"/>
        <ontology:isSuppliedBy rdf:resource="http://example.org/ontology#Risky_Supplier"/>
        <ontology:hasInventoryStock rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</ontology:hasInventoryStock>
        <ontology:hasSafetyStockLevel rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">50</ontology:hasSafetyStockLevel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Del_LateTest -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Del_LateTest">
        <rdf:type rdf:resource="http://example.org/ontology#DeliveryEvent"/>
