                                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasDelayPenaltyRate"/>
                                                                        <swrl:argument1 rdf:resource="http://example.org/ontology/sla"/>
                                                                        <swrl:argument2 rdf:resource="http://example.org/ontology/rate"/>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
