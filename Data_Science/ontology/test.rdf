                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#governs"/>
                                                                <swrl:argument1 rdf:resource="http://example.org/ontology/sla"/>
                                                                <swrl:argument2 rdf:resource="http://example.org/ontology/sup"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
