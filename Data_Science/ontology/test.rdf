                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#fulfills"/>
                                                <swrl:argument1 rdf:resource="http://example.org/ontology/d"/>
                                                <swrl:argument2 rdf:resource="http://example.org/ontology/po"/>
                                            </rdf:Description>
                                        </rdf:first>
