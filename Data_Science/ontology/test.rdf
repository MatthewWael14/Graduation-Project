                                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                                                                                <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#multiply"/>
                                                                                                <swrl:arguments rdf:parseType="Collection">
                                                                                                    <rdf:Description rdf:about="http://example.org/ontology/penalty"/>
                                                                                                    <rdf:Description rdf:about="http://example.org/ontology/days"/>
                                                                                                    <rdf:Description rdf:about="http://example.org/ontology/rate"/>
                                                                                                </swrl:arguments>
                                                                                            </rdf:Description>
                                                                                        </rdf:first>
