                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#issuedTo"/>
                                                                <swrl:argument1 rdf:resource="http://example.org/ontology/po"/>
                                                                <swrl:argument2 rdf:resource="http://example.org/ontology/sup"/>
