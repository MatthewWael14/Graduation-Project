    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment></rdfs:comment>
        <rdfs:label>PenaltyDelay</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://example.org/ontology#DeliveryEvent"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                <swrl:classPredicate rdf:resource="http://example.org/ontology#SLAViolation"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasViolationType"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                                        <swrl:argument2>LateDelivery</swrl:argument2>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#fulfills"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#po"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#issuedTo"/>
                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#po"/>
                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sup"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#governs"/>
                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sla"/>
                                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sup"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                <rdf:first>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasDelayPenaltyRate"/>
                                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sla"/>
                                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#rate"/>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                        <rdf:first>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
