    <!-- http://example.org/ontology#Event -->

    <owl:Class rdf:about="http://example.org/ontology#Event"/>
    


    <!-- http://example.org/ontology#FinalAssembly -->

    <owl:Class rdf:about="http://example.org/ontology#FinalAssembly">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#ProductionProcess"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#IncumbentSupplier -->

    <owl:Class rdf:about="http://example.org/ontology#IncumbentSupplier">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#LiquidMaterial -->

    <owl:Class rdf:about="http://example.org/ontology#LiquidMaterial">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RawMaterial"/>
        <owl:disjointWith rdf:resource="http://example.org/ontology#SolidMaterial"/>
