        <rdfs:subClassOf rdf:resource="http://example.org/ontology#ProductionProcess"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#DelayEvent -->

    <owl:Class rdf:about="http://example.org/ontology#DelayEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RiskEvent"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#DeliveryEvent -->

    <owl:Class rdf:about="http://example.org/ontology#DeliveryEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
