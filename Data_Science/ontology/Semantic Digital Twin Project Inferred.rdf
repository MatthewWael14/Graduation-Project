    </owl:Class>
    


    <!-- http://example.org/ontology#ProductionProcess -->

    <owl:Class rdf:about="http://example.org/ontology#ProductionProcess"/>
    


    <!-- http://example.org/ontology#PurchaseOrder -->

    <owl:Class rdf:about="http://example.org/ontology#PurchaseOrder"/>
    


    <!-- http://example.org/ontology#RawMaterial -->

    <owl:Class rdf:about="http://example.org/ontology#RawMaterial"/>
    


    <!-- http://example.org/ontology#RiskEvent -->

    <owl:Class rdf:about="http://example.org/ontology#RiskEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Route -->

    <owl:Class rdf:about="http://example.org/ontology#Route"/>
    


    <!-- http://example.org/ontology#SLAViolation -->

    <owl:Class rdf:about="http://example.org/ontology#SLAViolation">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RiskEvent"/>
