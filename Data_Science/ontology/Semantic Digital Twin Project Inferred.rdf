    <!-- http://example.org/ontology#AlternativeSupplier -->

    <owl:Class rdf:about="http://example.org/ontology#AlternativeSupplier">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Supplier"/>
        <owl:disjointWith rdf:resource="http://example.org/ontology#IncumbentSupplier"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#BusinessActor -->

    <owl:Class rdf:about="http://example.org/ontology#BusinessActor"/>
    


    <!-- http://example.org/ontology#CoatingProcess -->

