<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#"
     xml:base="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:ontology="http://example.org/ontology#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->

    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#affectsProcess -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#affectsProcess">
        <rdfs:domain rdf:resource="http://example.org/ontology#RawMaterial"/>
        <rdfs:range rdf:resource="http://example.org/ontology#ProductionProcess"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#appliesTo -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#appliesTo">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://example.org/ontology#RawMaterial"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#followsRoute -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#followsRoute">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#fulfills -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#fulfills">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://example.org/ontology#PurchaseOrder"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#governs -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#governs">
        <owl:inverseOf rdf:resource="http://example.org/ontology#hasSLA"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#hasSLA -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#hasSLA">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#SLA_Agreement"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#impacts -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#impacts">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://example.org/ontology#ProductionProcess"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#incursPenalty -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#incursPenalty">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#SLAViolation"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#isPerformedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#isPerformedBy">
        <owl:inverseOf rdf:resource="http://example.org/ontology#performsDeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#LogisticsProvider"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#isSuppliedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#isSuppliedBy">
        <owl:inverseOf rdf:resource="http://example.org/ontology#supplies"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RawMaterial"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#isTriggeredBy -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#isTriggeredBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Event"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#issuedTo -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#issuedTo">
        <rdfs:domain rdf:resource="http://example.org/ontology#PurchaseOrder"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#managesRoute -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#managesRoute">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#LogisticsProvider"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#performsDeliveryEvent -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#performsDeliveryEvent">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#LogisticsProvider"/>
        <rdfs:range rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Event"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#receivesInstructionsFor -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#receivesInstructionsFor">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#LogisticsProvider"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Route"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#replaces -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#replaces">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#AlternativeSupplier"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#IncumbentSupplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#supplies -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#supplies">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#RawMaterial"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#suppliesSameMaterialAs -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#suppliesSameMaterialAs">
        <rdfs:domain rdf:resource="http://example.org/ontology#AlternativeSupplier"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://example.org/ontology#IncumbentSupplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#transports -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#transports">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://example.org/ontology#RawMaterial"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/ontology#utilizesRoute -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology#utilizesRoute">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology#Route"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#hasActualArrivalDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasActualArrivalDate">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasActualDepartureTime -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasActualDepartureTime">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasContractID -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasContractID">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasCriticalityLevel -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasCriticalityLevel">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Critical</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>High</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Low</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Medium</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasCurrency -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasCurrency">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDelayDuration -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDelayDuration">
        <rdfs:domain rdf:resource="http://example.org/ontology#DelayEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDelayPenaltyRate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDelayPenaltyRate">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDeliveredQuantity -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDeliveredQuantity">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDeliveryStatus -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDeliveryStatus">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Delayed</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Delivered</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Scheduled</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Shipped</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDimensions -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDimensions">
        <rdfs:domain rdf:resource="http://example.org/ontology#RawMaterial"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#SolidMaterial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDiscoveryTimestamp -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDiscoveryTimestamp">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDisruptionStatus -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDisruptionStatus">
        <rdfs:domain rdf:resource="http://example.org/ontology#ProductionProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasDowntimeDuration -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasDowntimeDuration">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasEstimatedFinancialImpact -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasEstimatedFinancialImpact">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasExpectedDeliveryDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasExpectedDeliveryDate">
        <rdfs:domain rdf:resource="http://example.org/ontology#PurchaseOrder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasInventoryStock -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasInventoryStock">
        <rdfs:domain rdf:resource="http://example.org/ontology#RawMaterial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasMaterialID -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasMaterialID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RawMaterial"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasMinQualityThreshold -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasMinQualityThreshold">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasMissedItemPenaltyRate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasMissedItemPenaltyRate">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasName -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasOrderDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasOrderDate">
        <rdfs:domain rdf:resource="http://example.org/ontology#PurchaseOrder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasOrderedQuantity -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasOrderedQuantity">
        <rdfs:domain rdf:resource="http://example.org/ontology#PurchaseOrder"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasPenaltyAmount -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasPenaltyAmount">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#SLAViolation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasPlannedArrivalDate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasPlannedArrivalDate">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasPlannedDepartureTime -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasPlannedDepartureTime">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasPredictedLeadTime -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasPredictedLeadTime">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasProbability -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasProbability">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasProcessID -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasProcessID">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#ProductionProcess"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasQualityPenaltyRate -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasQualityPenaltyRate">
        <rdfs:domain rdf:resource="http://example.org/ontology#SLA_Agreement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasQualityScore -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasQualityScore">
        <rdfs:domain rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasReasonCode -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasReasonCode">
        <rdfs:domain rdf:resource="http://example.org/ontology#DelayEvent"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>CarrierIssue</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>CustomsDelay</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>PortCongestion</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Transport/Weather</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasReliabilityScore -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasReliabilityScore">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasReliabilityTier -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasReliabilityTier">
        <rdfs:domain rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#Supplier"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>High</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Low</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Medium</rdf:first>
                                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/ontology#hasRiskStatus -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology#hasRiskStatus">
        <rdfs:domain rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:domain rdf:resource="http://example.org/ontology#RiskEvent"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Confirmed</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Predicted</rdf:first>
                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
    </owl:DatatypeProperty>
    


