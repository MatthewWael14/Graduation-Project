                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                                <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThan"/>
                                                <swrl:arguments rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#stock"/>
                                                    <rdf:Description rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#safe"/>
                                                </swrl:arguments>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
