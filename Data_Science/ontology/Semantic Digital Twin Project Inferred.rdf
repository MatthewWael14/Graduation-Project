        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Variable"/>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment></rdfs:comment>
        <rdfs:label>PenaltyQuality</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://example.org/ontology#DeliveryEvent"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                                <swrl:classPredicate rdf:resource="http://example.org/ontology#SLAViolation"/>
                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasViolationType"/>
                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                                        <swrl:argument2>DamagedGoods</swrl:argument2>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#fulfills"/>
                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#po"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasTotalOrderCost"/>
                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#po"/>
                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#cost"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#issuedTo"/>
                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#po"/>
                                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sup"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                <rdf:first>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#governs"/>
                                                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sla"/>
                                                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sup"/>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                        <rdf:first>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasQualityPenaltyRate"/>
                                                                                <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#sla"/>
                                                                                <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#rate"/>
                                                                            </rdf:Description>
                                                                        </rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                                <rdf:first>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                                                                        <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#multiply"/>
                                                                                        <swrl:arguments rdf:parseType="Collection">
                                                                                            <rdf:Description rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#penalty"/>
                                                                                            <rdf:Description rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#cost"/>
                                                                                            <rdf:Description rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#rate"/>
                                                                                        </swrl:arguments>
                                                                                    </rdf:Description>
                                                                                </rdf:first>
                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasPenaltyAmount"/>
                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#d"/>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#penalty"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>
    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Downtime = delivery delay</rdfs:comment>
        <rdfs:label>DowntimeCalculation</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
