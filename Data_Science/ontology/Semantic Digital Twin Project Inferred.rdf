     -->

    


    <!-- http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Assembly_Line_02 -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Assembly_Line_02">
        <rdf:type rdf:resource="http://example.org/ontology#Event"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionProcess"/>
        <rdf:type rdf:resource="http://example.org/ontology#RiskEvent"/>
        <ontology:hasCriticalityLevel>Medium</ontology:hasCriticalityLevel>
        <ontology:hasProcessID>PROC_M</ontology:hasProcessID>
        <ontology:hasRiskStatus>Confirmed</ontology:hasRiskStatus>
        <ontology:isCriticalPath rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ontology:isCriticalPath>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Delivery_LowTest -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Delivery_LowTest">
        <rdf:type rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdf:type rdf:resource="http://example.org/ontology#Event"/>
        <ontology:transports rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Material_LowTest"/>
        <ontology:hasDeliveryStatus>Delayed</ontology:hasDeliveryStatus>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Delivery_MediumTest -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Delivery_MediumTest">
        <rdf:type rdf:resource="http://example.org/ontology#DeliveryEvent"/>
        <rdf:type rdf:resource="http://example.org/ontology#Event"/>
        <ontology:transports rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Material_Critical_Medium"/>
        <ontology:hasDeliveryStatus>Delayed</ontology:hasDeliveryStatus>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Material_Critical_Medium -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Material_Critical_Medium">
        <rdf:type rdf:resource="http://example.org/ontology#RawMaterial"/>
        <ontology:affectsProcess rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Assembly_Line_02"/>
        <ontology:hasInventoryStock rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">100</ontology:hasInventoryStock>
        <ontology:hasSafetyStockLevel rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">50</ontology:hasSafetyStockLevel>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Material_LowTest -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Material_LowTest">
        <rdf:type rdf:resource="http://example.org/ontology#RawMaterial"/>
        <ontology:affectsProcess rdf:resource="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Process_LowTest"/>
        <ontology:hasInventoryStock rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">300</ontology:hasInventoryStock>
        <ontology:hasSafetyStockLevel rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">200</ontology:hasSafetyStockLevel>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Process_LowTest -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/matt/ontologies/2026/2/untitled-ontology-30#Process_LowTest">
        <rdf:type rdf:resource="http://example.org/ontology#Event"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionProcess"/>
        <rdf:type rdf:resource="http://example.org/ontology#RiskEvent"/>
        <ontology:hasCriticalityLevel>Low</ontology:hasCriticalityLevel>
        <ontology:hasProcessID>PROC_L</ontology:hasProcessID>
        <ontology:hasRiskStatus>Predicted</ontology:hasRiskStatus>
        <ontology:isCriticalPath rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ontology:isCriticalPath>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Assembly_Line_01 -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Assembly_Line_01">
        <rdf:type rdf:resource="http://example.org/ontology#Event"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionDisruption"/>
        <rdf:type rdf:resource="http://example.org/ontology#ProductionProcess"/>
        <rdf:type rdf:resource="http://example.org/ontology#RiskEvent"/>
        <ontology:hasCriticalityLevel>High</ontology:hasCriticalityLevel>
        <ontology:hasDisruptionStatus>Risk of Stoppage</ontology:hasDisruptionStatus>
        <ontology:hasDowntimeDuration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</ontology:hasDowntimeDuration>
        <ontology:hasRiskStatus>Confirmed</ontology:hasRiskStatus>
        <ontology:isCriticalPath rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</ontology:isCriticalPath>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Average_Supplier_Y -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Average_Supplier_Y">
        <rdf:type rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdf:type rdf:resource="http://example.org/ontology#Supplier"/>
        <ontology:hasReliabilityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.65</ontology:hasReliabilityScore>
        <ontology:hasReliabilityTier>Medium</ontology:hasReliabilityTier>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Critical_Component -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Critical_Component">
        <rdf:type rdf:resource="http://example.org/ontology#RawMaterial"/>
