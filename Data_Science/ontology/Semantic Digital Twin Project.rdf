    <!-- http://example.org/ontology#AlternativeSupplier -->

    <owl:Class rdf:about="http://example.org/ontology#AlternativeSupplier">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Supplier"/>
        <owl:disjointWith rdf:resource="http://example.org/ontology#IncumbentSupplier"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#BusinessActor -->

    <owl:Class rdf:about="http://example.org/ontology#BusinessActor"/>
    


    <!-- http://example.org/ontology#DelayEvent -->

    <owl:Class rdf:about="http://example.org/ontology#DelayEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RiskEvent"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#DeliveryEvent -->

    <owl:Class rdf:about="http://example.org/ontology#DeliveryEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Event -->

    <owl:Class rdf:about="http://example.org/ontology#Event"/>
    


    <!-- http://example.org/ontology#IncumbentSupplier -->

    <owl:Class rdf:about="http://example.org/ontology#IncumbentSupplier">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#ProductionDisruption -->

    <owl:Class rdf:about="http://example.org/ontology#ProductionDisruption">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RiskEvent"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#ProductionProcess -->

    <owl:Class rdf:about="http://example.org/ontology#ProductionProcess"/>
    


    <!-- http://example.org/ontology#PurchaseOrder -->

    <owl:Class rdf:about="http://example.org/ontology#PurchaseOrder"/>
    


    <!-- http://example.org/ontology#RawMaterial -->

    <owl:Class rdf:about="http://example.org/ontology#RawMaterial"/>
    


    <!-- http://example.org/ontology#RiskEvent -->

    <owl:Class rdf:about="http://example.org/ontology#RiskEvent">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#Event"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Route -->

    <owl:Class rdf:about="http://example.org/ontology#Route"/>
    


    <!-- http://example.org/ontology#SLAViolation -->

    <owl:Class rdf:about="http://example.org/ontology#SLAViolation">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#RiskEvent"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#SLA_Agreement -->

    <owl:Class rdf:about="http://example.org/ontology#SLA_Agreement">
        <owl:disjointWith rdf:resource="http://example.org/ontology#Supplier"/>
    </owl:Class>
    


    <!-- http://example.org/ontology#Supplier -->

    <owl:Class rdf:about="http://example.org/ontology#Supplier">
        <rdfs:subClassOf rdf:resource="http://example.org/ontology#BusinessActor"/>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/ontology#Apex_Electronics -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Apex_Electronics">
        <rdf:type rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdf:type rdf:resource="http://example.org/ontology#Supplier"/>
        <hasSLA rdf:resource="http://example.org/ontology#SLA_EcoLithium_Premium"/>
        <supplies rdf:resource="http://example.org/ontology#Electric_Motor_Rotor"/>
        <supplies rdf:resource="http://example.org/ontology#Structural_Steel_Sheet"/>
        <hasReliabilityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.6</hasReliabilityScore>
        <hasReliabilityTier>Medium</hasReliabilityTier>
        <leadTimeDays rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</leadTimeDays>
        <penaltyClause>SLA Penalty: $400 per day after 2-day grace period</penaltyClause>
        <penaltyRatePerDay rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">400</penaltyRatePerDay>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Apex_Motor_Backup -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Apex_Motor_Backup">
        <rdf:type rdf:resource="http://example.org/ontology#AlternativeSupplier"/>
        <supplies rdf:resource="http://example.org/ontology#Electric_Motor_Rotor"/>
        <hasReliabilityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.91</hasReliabilityScore>
        <leadTimeDays rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</leadTimeDays>
        <country>JP</country>
        <rdfs:label>Apex Motor Backup</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Aura_Steel_Backup -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Aura_Steel_Backup">
        <rdf:type rdf:resource="http://example.org/ontology#AlternativeSupplier"/>
        <supplies rdf:resource="http://example.org/ontology#Microcontroller_Chip"/>
        <hasReliabilityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.88</hasReliabilityScore>
        <leadTimeDays rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</leadTimeDays>
        <country>DE</country>
        <rdfs:label>Aura Steel Backup</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Aura_Steel_Co -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Aura_Steel_Co">
        <rdf:type rdf:resource="http://example.org/ontology#BusinessActor"/>
        <rdf:type rdf:resource="http://example.org/ontology#Supplier"/>
        <hasSLA rdf:resource="http://example.org/ontology#SLA_AuraSteel_Standard"/>
        <supplies rdf:resource="http://example.org/ontology#Microcontroller_Chip"/>
        <hasReliabilityScore rdf:datatype="http://www.w3.org/2001/XMLSchema#float">0.2</hasReliabilityScore>
        <hasReliabilityTier>Low</hasReliabilityTier>
    </owl:NamedIndividual>
    


    <!-- http://example.org/ontology#Customs_Delay_Log -->

    <owl:NamedIndividual rdf:about="http://example.org/ontology#Customs_Delay_Log">
