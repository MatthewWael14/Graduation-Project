    <rdf:Description>
        <swrla:isRuleEnabled rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</swrla:isRuleEnabled>
        <rdfs:comment>Downtime = delivery delay</rdfs:comment>
        <rdfs:label>DowntimeCalculation</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
                        <swrl:classPredicate rdf:resource="http://example.org/ontology#DeliveryEvent"/>
                        <swrl:argument1 rdf:resource="http://example.org/ontology/d"/>
                    </rdf:Description>
                </rdf:first>
                <rdf:rest>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                        <rdf:first>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasDeliveryStatus"/>
                                <swrl:argument1 rdf:resource="http://example.org/ontology/d"/>
                                <swrl:argument2>Delayed</swrl:argument2>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                <rdf:first>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#transports"/>
                                        <swrl:argument1 rdf:resource="http://example.org/ontology/d"/>
                                        <swrl:argument2 rdf:resource="http://example.org/ontology/m"/>
                                    </rdf:Description>
                                </rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                        <rdf:first>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#affectsProcess"/>
                                                <swrl:argument1 rdf:resource="http://example.org/ontology/m"/>
                                                <swrl:argument2 rdf:resource="http://example.org/ontology/p"/>
                                            </rdf:Description>
                                        </rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                <rdf:first>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasInventoryStock"/>
                                                        <swrl:argument1 rdf:resource="http://example.org/ontology/m"/>
                                                        <swrl:argument2 rdf:resource="http://example.org/ontology/stock"/>
                                                    </rdf:Description>
                                                </rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                        <rdf:first>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasSafetyStockLevel"/>
                                                                <swrl:argument1 rdf:resource="http://example.org/ontology/m"/>
                                                                <swrl:argument2 rdf:resource="http://example.org/ontology/safe"/>
                                                            </rdf:Description>
                                                        </rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                <rdf:first>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                                                        <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThan"/>
                                                                        <swrl:arguments rdf:parseType="Collection">
                                                                            <rdf:Description rdf:about="http://example.org/ontology/stock"/>
                                                                            <rdf:Description rdf:about="http://example.org/ontology/safe"/>
                                                                        </swrl:arguments>
                                                                    </rdf:Description>
                                                                </rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                        <rdf:first>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                                                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#isTriggeredBy"/>
                                                                                <swrl:argument1 rdf:resource="http://example.org/ontology/delayEvent"/>
                                                                                <swrl:argument2 rdf:resource="http://example.org/ontology/d"/>
                                                                            </rdf:Description>
                                                                        </rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                                                                                <rdf:first>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom"/>
                                                                                        <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasDelayDuration"/>
                                                                                        <swrl:argument1 rdf:resource="http://example.org/ontology/delayEvent"/>
                                                                                        <swrl:argument2 rdf:resource="http://example.org/ontology/time"/>
                                                                                    </rdf:Description>
                                                                                </rdf:first>
                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
