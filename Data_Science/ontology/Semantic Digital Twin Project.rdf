                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#BuiltinAtom"/>
                                                <swrl:builtin rdf:resource="http://www.w3.org/2003/11/swrlb#lessThanOrEqual"/>
                                                <swrl:arguments rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="http://example.org/ontology/actDep"/>
                                                    <rdf:Description rdf:about="http://example.org/ontology/planDep"/>
