                                <swrl:propertyPredicate rdf:resource="http://example.org/ontology#hasActualDepartureTime"/>
                                <swrl:argument1 rdf:resource="http://example.org/ontology/d"/>
                                <swrl:argument2 rdf:resource="http://example.org/ontology/actDep"/>
